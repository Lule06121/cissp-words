  ,
  {
    "id": "d8-011", "domain": "D8: ソフトウェア開発セキュリティ",
    "term": "Waterfall Model", "term_en": "Waterfall Model",
    "definition": "要件定義、設計、実装、テスト、運用と、各工程を順番に完了させながら進める伝統的なソフトウェア開発手法。",
    "definition_en": "A traditional, linear, sequential approach to software design and development where each phase must be completed before the next begins."
  },
  {
    "id": "d8-012", "domain": "D8: ソフトウェア開発セキュリティ",
    "term": "Agile Methodology", "term_en": "Agile Methodology",
    "definition": "短いサイクル（スプリント）で開発とテストを反復し、要件の変更に柔軟に対応するソフトウェア開発手法。",
    "definition_en": "An iterative approach to software development that emphasizes flexibility, collaboration, and rapid delivery of functional components."
  },
  {
    "id": "d8-013", "domain": "D8: ソフトウェア開発セキュリティ",
    "term": "DevSecOps", "term_en": "DevSecOps",
    "definition": "開発（Dev）と運用（Ops）のプロセス全体を通じて、セキュリティ（Sec）の責任とテストを統合・自動化するアプローチ。",
    "definition_en": "The integration of security practices and testing continuously throughout the entire software development lifecycle and operations."
  },
  {
    "id": "d8-014", "domain": "D8: ソフトウェア開発セキュリティ",
    "term": "Input Validation", "term_en": "Input Validation",
    "definition": "ユーザーや外部からシステムに入力されるデータが、想定された形式や長さ、文字種に適合しているかを検証すること。注入攻撃を防ぐ基本。",
    "definition_en": "The practice of testing all input supplied to an application to ensure it conforms to expected formats and prevents injection attacks."
  },
  {
    "id": "d8-015", "domain": "D8: ソフトウェア開発セキュリティ",
    "term": "SQL Injection", "term_en": "SQL Injection (SQLi)",
